<%- include("partials/header") %>

  <div class="event-header">
    <h1>
      <%= event.name %>
    </h1>
    <span class="join-code-pill">
      <%= event.join_code %>
    </span>
  </div>

  <div class="event-layout">

    <!-- Left: Members -->
    <div class="panel">
      <h3>Members</h3>
      <ul class="member-list">
        <% members.forEach(member=> { %>
          <li>
            <div class="member-avatar">
              <%= member.email[0].toUpperCase() %>
            </div>
            <div class="member-info">
              <span class="member-email">
                <%= member.email %>
              </span>
              <span class="member-spent">₹<%= member.totalSpent.toFixed(2) %> paid</span>
            </div>
          </li>
          <% }) %>
      </ul>
    </div>

    <!-- Right: Expenses -->
    <div class="panel">
      <h3>Expenses</h3>

      <% if (expenses.length===0) { %>
        <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 16px;">
          No expenses yet. Add the first one below.
        </p>
        <% } else { %>
          <div class="expense-list">
            <% expenses.forEach(exp=> { %>
              <div class="expense-card">
                <div class="expense-info">
                  <span class="expense-desc">
                    <%= exp.description %>
                  </span>
                  <span class="expense-amount">₹<%= Number(exp.amount).toFixed(2) %></span>
                </div>
                <form action="/expenses/delete/<%= exp.id %>" method="POST">
                  <input type="hidden" name="eventID" value="<%= event.id %>">
                  <button type="submit" class="btn btn-danger">Delete</button>
                </form>
              </div>
              <% }) %>
          </div>
          <% } %>

            <form action="/expenses/add/<%= event.id %>" method="POST" class="add-expense-form">
              <div class="form-group">
                <label>Description</label>
                <input type="text" name="description" placeholder="e.g. Dinner" required>
              </div>
              <div class="form-group">
                <label>Amount (₹)</label>
                <input type="number" name="amount" placeholder="0.00" min="0.01" step="0.01" required>
              </div>
              <button type="submit" class="btn btn-primary" style="margin-bottom:0; align-self: flex-end;">Add</button>
            </form>
    </div>

    <!-- Balance Panel -->
    <div class="panel">
      <h3>Split Summary</h3>
      <div style="display: flex; flex-direction: column; gap: 12px;">

        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span style="font-size: 14px; color: var(--text-muted);">Total expenses</span>
          <span style="font-family: var(--font-mono); font-weight: 600;">
            ₹<%= expenses.reduce((sum, e)=> sum + Number(e.amount), 0).toFixed(2) %>
          </span>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span style="font-size: 14px; color: var(--text-muted);">Members</span>
          <span style="font-family: var(--font-mono); font-weight: 600;">
            <%= members.length %>
          </span>
        </div>

        <div
          style="border-top: 1px solid var(--border); padding-top: 12px; display: flex; justify-content: space-between; align-items: center;">
          <span style="font-size: 14px; font-weight: 600;">Your balance</span>
          <% const balanceClass=perHeadAmount>= 0 ? 'balance-positive-text' : 'balance-negative-text' %>
            <span class="balance-figure <%= balanceClass %>">
              <%= perHeadAmount>= 0 ? '+' : '' %>₹<%= Math.abs(perHeadAmount).toFixed(2) %>
            </span>
        </div>

        <div style="font-size: 12px; color: var(--text-muted); text-align: right;">
          <% if (perHeadAmount> 0.01) { %>
            Others owe you
            <% } else if (perHeadAmount < -0.01) { %>
              You owe others
              <% } else { %>
                You're settled up ✓
                <% } %>
        </div>

      </div>
    </div>

  </div>

  <%- include("partials/footer") %>