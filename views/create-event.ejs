<%- include("partials/header") %>

  <div style="max-width: 440px; margin: 0 auto;">
    <div class="auth-card">

      <h2>Create Event</h2>
      <p class="subtitle">Give your event a name and share the code with your crew</p>

      <form action="/events/create" method="POST">
        <div class="form-group">
          <label for="name">Event Name</label>
          <input type="text" id="name" name="name" placeholder="e.g. Goa Trip 2026" required>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Create Event</button>
      </form>

    </div>
  </div>

  <%- include("partials/footer") %>