<%- include("partials/header") %>

  <div class="page-header">
    <h1>Your Events</h1>
    <div class="actions">
      <a href="/events/create" class="btn btn-primary">+ Create Event</a>
      <a href="/events/join" class="btn btn-secondary">Join Event</a>
    </div>
  </div>

  <!-- Joined Events -->
  <p class="section-title">Joined Events</p>

  <% if (joinedEvents.length===0) { %>
    <div class="empty-state">
      You haven't joined any events yet. Ask a friend for their join code.
    </div>
    <% } else { %>
      <div class="event-grid">
        <% joinedEvents.forEach(event=> { %>
          <div class="event-card">
            <h3>
              <%= event.name %>
            </h3>
            <span class="join-code-pill">
              <%= event.join_code %>
            </span>
            <a href="/events/<%= event.id %>" class="open-link">Open event →</a>
          </div>
          <% }) %>
      </div>
      <% } %>

        <!-- Created Events -->
        <p class="section-title">Created by You</p>

        <% if (events.length===0) { %>
          <div class="empty-state">
            No events yet. <a href="/events/create">Create your first one →</a>
          </div>
          <% } else { %>
            <div class="event-grid">
              <% events.forEach(event=> { %>
                <div class="event-card">
                  <h3>
                    <%= event.name %>
                  </h3>
                  <span class="join-code-pill">
                    <%= event.join_code %>
                  </span>
                  <a href="/events/<%= event.id %>" class="open-link">Open event →</a>
                </div>
                <% }) %>
            </div>
            <% } %>

              <%- include("partials/footer") %>