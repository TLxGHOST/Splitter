<%- include("partials/header") %>

  <h1>Your Events</h1>

  <h2>Joined Events</h2>

  <% if(joinedEvents.length===0){ %>
    <p>You haven't joined any events yet.</p>
  <% } else { %>
    <div class="event-grid">
      <% joinedEvents.forEach(event=> { %>
        <div class="event-card">
          <h3><%= event.name %></h3>
          <p>Join Code: <%= event.join_code %></p>
          <a href="/events/<%= event.id %>">Open</a>
        </div>
      <% }) %>
    </div>
  <% } %>

  <h2>Your Events</h2>

  <% if(events.length===0){ %>

    <p>No events yet. Create one!</p>

    <% } %>
      <div class="event-grid">

        <% events.forEach(event=> { %>

          <div class="event-card">

            <h3>
              <%= event.name %>
            </h3>

            <p>Join Code: <%= event.join_code %>
            </p>

            <a href="/events/<%= event.id %>">Open</a>

          </div>

          <% }) %>
          

      </div>
      <div class="actions" style="margin-top: 15px;">

        <form action="/events/create" method="GET" style="display:inline;">
          <button class="btn-primary">Create Event</button>
        </form>

        <form action="/events/join" method="GET" style="display:inline;">
          <button class="btn-secondary">Join Event</button>
        </form>

      </div>




      <%- include("partials/footer") %>